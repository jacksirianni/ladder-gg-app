generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum LeagueState {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PayoutPreset {
  WTA
  TOP_2
  TOP_3
}

enum PaymentStatus {
  PENDING
  PAID
  WAIVED
  REFUNDED
}

enum MatchStatus {
  PENDING
  AWAITING_REPORT
  AWAITING_CONFIRM
  CONFIRMED
  DISPUTED
  ORGANIZER_DECIDED
}

// v2.0: tournament format. Single-elimination is the legacy default;
// double-elimination adds a losers bracket so a single loss doesn't
// eliminate you. v2.0-A only supports power-of-2 team counts in DE
// (no byes); single-elim continues to support any count via byes.
enum LeagueFormat {
  SINGLE_ELIM
  DOUBLE_ELIM
}

// v2.0: which bracket a match lives in. Only meaningful when
// `League.format = DOUBLE_ELIM`. Single-elim leagues store every
// match as `WINNERS` for backward compatibility.
//
//   WINNERS      — main bracket; one loss drops you to LOSERS
//   LOSERS       — losers bracket; second loss eliminates you
//   GRAND_FINAL  — WB-final winner vs LB-final winner (one match)
//   GRAND_RESET  — optional second GF if LB winner takes the first
//                  (only generated when League.allowBracketReset = true)
enum MatchBracket {
  WINNERS
  LOSERS
  GRAND_FINAL
  GRAND_RESET
}

// v1.6: how captains are allowed to find / join a league. Distinct from
// LeagueState (which models lifecycle) — visibility is a join-policy
// switch the organizer flips independently of the bracket lifecycle.
enum LeagueVisibility {
  // Public page renders, but the page is noindex/nofollow and excluded
  // from the sitemap. Captains need an invite link to register.
  INVITE_ONLY
  // Public page is indexable but not actively promoted. Captains still
  // need an invite link to register. Default for existing rows.
  UNLISTED
  // Public page is indexable. Anyone signed in can register a team
  // directly from the public page while spots remain.
  OPEN_JOIN
}

// v1.7: how a match's score is structured. League-level setting; locked
// once the bracket starts so retroactive interpretation can't change.
//   BEST_OF_3 / BEST_OF_5 / BEST_OF_7 — wins-based, winner derived
//   SINGLE_SCORE — single game with optional structured score (e.g. 4-1
//                  goals, 13-9 rounds); winner explicitly chosen
//   FREEFORM — text-only score (e.g. Mario Kart cup totals)
enum MatchFormat {
  BEST_OF_3
  BEST_OF_5
  BEST_OF_7
  SINGLE_SCORE
  FREEFORM
}

// v1.7: types of external evidence captains/organizers can attach to a
// match. Manual confirmation remains the source of truth — evidence is
// informational only and never gates the confirm/dispute flow.
enum EvidenceKind {
  SCREENSHOT     // URL to image-hosted scoreboard/screenshot
  VOD_LINK       // YouTube / Twitch / similar
  REPLAY_CODE    // in-game replay identifier (alphanumeric)
  MATCH_LINK     // Tracker.gg / OP.gg / Blitz / other aggregator URL
  PROFILE_LINK   // similar but for a player profile, not a match
  NOTE           // free-form text note
}

// v1.7: external platforms a user can list on their public profile.
// We never call these platforms' APIs in v1.7 — the user pastes their
// identifier or URL and we display it. No verification.
enum ExternalPlatform {
  BATTLENET
  TRACKER_GG
  STEAM
  RIOT_ID
  EPIC
  XBOX
  PSN
  NINTENDO
  OTHER
}

model User {
  id                       String                @id @default(cuid())
  email                    String                @unique
  emailVerified            DateTime?
  passwordHash             String
  displayName              String
  // v1.5: short URL handle for `/p/[handle]`. Nullable in schema so existing
  // rows can be backfilled; runtime always populates for new signups.
  handle                   String?               @unique
  // v2.0: avatar URL (Vercel Blob) + 200-char bio. Display-only.
  avatarUrl                String?
  bio                      String?
  // v2.0-B: master opt-out for transactional notification emails.
  // Default true (opt-in by default for new + existing users); user
  // can flip on /account.
  emailNotifications       Boolean               @default(true)
  ageConfirmed             Boolean               @default(false)
  stripeConnectedAccountId String?
  accounts                 Account[]
  sessions                 Session[]
  organizedLeagues         League[]
  organizedSeasons         Season[]              @relation("UserSeasons")
  captainedTeams           Team[]
  matchReports             MatchReport[]         @relation("MatchReportReporter")
  matchesResolved          Match[]               @relation("MatchResolver")
  matchesDisputed          Match[]               @relation("MatchDisputer")
  // v1.7: evidence the user has attached to matches (any role).
  evidenceSubmitted        MatchEvidence[]       @relation("EvidenceSubmitter")
  // v1.7: external profile links (BattleTag, Tracker.gg, Riot ID, etc.).
  externalProfiles         UserExternalProfile[]
  // v1.8: handle history — keeps old `/p/[handle]` links working for a
  // grace period after the user changes their handle.
  handleHistory            UserHandleHistory[]
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model League {
  id                   String       @id @default(cuid())
  slug                 String       @unique
  name                 String
  description          String?
  game                 String
  teamSize             Int
  maxTeams             Int
  buyInCents           Int
  payoutPreset         PayoutPreset @default(WTA)
  paymentInstructions  String?
  prizeNotes           String?
  state                LeagueState      @default(DRAFT)
  // v1.6: how captains can join. UNLISTED keeps existing behavior for
  // legacy rows (public page works, invite token required to join).
  visibility           LeagueVisibility @default(UNLISTED)
  organizerId          String
  // v1.5: optional grouping with other leagues from the same organizer.
  seasonId             String?
  inviteToken          String           @unique
  publishedAt          DateTime?
  registrationClosesAt DateTime?
  // v1.6: scheduled start time. Distinct from `startedAt`, which records
  // when the bracket was actually generated. Informational — we don't
  // enforce or block on it.
  startsAt             DateTime?
  // v1.6: organizer-toggled signal that the league wants more teams.
  // Display logic in the UI also gates this on state/capacity/deadline.
  lookingForTeams      Boolean          @default(false)
  // v1.7: how match scores are structured. Locked once IN_PROGRESS so
  // existing reports can't be reinterpreted under new rules.
  matchFormat          MatchFormat      @default(SINGLE_SCORE)
  // v1.9: optional override for the final match. When set, the highest-
  // round match in the bracket uses this format; all other matches
  // use `matchFormat`. Common pattern: BO3 throughout, BO5 final.
  finalMatchFormat     MatchFormat?
  // v2.0: tournament format. Locked once IN_PROGRESS.
  format               LeagueFormat     @default(SINGLE_ELIM)
  // v2.0: in DOUBLE_ELIM, whether the LB winner taking the first GF
  // triggers a second GF (the "bracket reset"). Default on; some
  // organizers prefer a single GF for time.
  allowBracketReset    Boolean          @default(true)
  // v1.7: free-form rules text — ruleset, region, special restrictions.
  rules                String?
  // v1.7: free-form map pool — newline-separated, organizer-managed.
  mapPool              String?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  organizer User    @relation(fields: [organizerId], references: [id], onDelete: Restrict)
  season    Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  teams     Team[]
  matches   Match[]

  @@index([organizerId])
  @@index([seasonId])
}

// v1.5: groups multiple leagues into a recurring series. The organizer of
// the season also organizes (or at least owns) every league in it.
model Season {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  organizerId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer User     @relation("UserSeasons", fields: [organizerId], references: [id], onDelete: Restrict)
  leagues   League[]

  @@index([organizerId])
}

model Team {
  id             String        @id @default(cuid())
  leagueId       String
  name           String
  captainUserId  String
  paymentStatus  PaymentStatus @default(PENDING)
  finalPlacement Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  league               League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  captain              User              @relation(fields: [captainUserId], references: [id], onDelete: Restrict)
  roster               TeamRosterEntry[]
  matchesAsTeamA       Match[]           @relation("MatchTeamA")
  matchesAsTeamB       Match[]           @relation("MatchTeamB")
  matchesWon           Match[]           @relation("MatchWinner")
  matchReportsAsWinner MatchReport[]     @relation("MatchReportWinner")

  @@unique([leagueId, captainUserId])
  @@index([leagueId])
  @@index([captainUserId])
}

model TeamRosterEntry {
  id          String   @id @default(cuid())
  teamId      String
  displayName String
  position    Int
  createdAt   DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, position])
  @@index([teamId])
}

model Match {
  id               String      @id @default(cuid())
  leagueId         String
  round            Int
  bracketPosition  Int
  teamAId          String?
  teamBId          String?
  winnerTeamId     String?
  status           MatchStatus @default(PENDING)
  // v2.0: which bracket this match is in. Default WINNERS for legacy
  // (single-elim) leagues — they only have one bracket.
  bracket          MatchBracket @default(WINNERS)
  // v1.7: structured scores. Interpretation depends on League.matchFormat:
  //   BO-N: games won by each team (winner derived from these)
  //   SINGLE_SCORE: optional points/rounds/goals (winner explicit on Match)
  //   FREEFORM: ignored, scoreText on the latest report is the source
  teamAScore       Int?
  teamBScore       Int?
  confirmedAt      DateTime?
  resolvedByUserId String?
  disputedAt       DateTime?
  disputedByUserId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  league     League          @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teamA      Team?           @relation("MatchTeamA", fields: [teamAId], references: [id], onDelete: SetNull)
  teamB      Team?           @relation("MatchTeamB", fields: [teamBId], references: [id], onDelete: SetNull)
  winner     Team?           @relation("MatchWinner", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  resolvedBy User?           @relation("MatchResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  disputedBy User?           @relation("MatchDisputer", fields: [disputedByUserId], references: [id], onDelete: SetNull)
  reports    MatchReport[]
  // v1.7: external evidence — replay codes, screenshots, VOD links, etc.
  evidence   MatchEvidence[]

  // v2.0: bracket added so WB and LB matches with the same
  // (leagueId, round, bracketPosition) don't collide in DE leagues.
  // Single-elim leagues all have bracket = WINNERS so this stays
  // backward-compatible.
  @@unique([leagueId, bracket, round, bracketPosition])
  @@index([leagueId])
}

model MatchReport {
  id                   String   @id @default(cuid())
  matchId              String
  reportedByUserId     String
  reportedWinnerTeamId String
  scoreText            String?
  // v1.7: structured scores reported. Mirrors Match.teamAScore /
  // teamBScore so a dispute can show the disagreement.
  reportedTeamAScore   Int?
  reportedTeamBScore   Int?
  createdAt            DateTime @default(now())

  match              Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reportedBy         User  @relation("MatchReportReporter", fields: [reportedByUserId], references: [id], onDelete: Restrict)
  reportedWinnerTeam Team  @relation("MatchReportWinner", fields: [reportedWinnerTeamId], references: [id], onDelete: Restrict)

  @@index([matchId])
}

// v1.7: a piece of external evidence attached to a match. Submitted by
// captains during reporting/dispute, or by the organizer during dispute
// resolution. Always attached to the match itself (not the report) so
// it survives report edits and groups naturally by submitter role.
//
// Exactly one of `url` or `textValue` is populated based on `kind`:
//   SCREENSHOT/VOD_LINK/MATCH_LINK/PROFILE_LINK → url
//   REPLAY_CODE/NOTE                            → textValue
model MatchEvidence {
  id                String       @id @default(cuid())
  matchId           String
  submittedByUserId String
  kind              EvidenceKind
  url               String?
  textValue         String?
  caption           String?
  createdAt         DateTime     @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation("EvidenceSubmitter", fields: [submittedByUserId], references: [id], onDelete: Restrict)

  @@index([matchId])
  @@index([submittedByUserId])
}

// v1.8: when a user changes their handle, the old handle is moved into
// this table with a grace-period TTL. Lookups for `/p/[handle]` fall
// back here when not in `User`, returning a permanent redirect to the
// user's current handle. Old shared links keep working.
model UserHandleHistory {
  id        String   @id @default(cuid())
  userId    String
  handle    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// v1.7: external profile link (BattleTag, Tracker.gg URL, Riot ID, etc.)
// Display-only — LADDER never calls these platforms' APIs in v1.7.
// At least one of `identifier` or `url` must be set (validated server-
// side, not at the schema level so we keep both nullable).
model UserExternalProfile {
  id         String           @id @default(cuid())
  userId     String
  platform   ExternalPlatform
  identifier String?
  url        String?
  label      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

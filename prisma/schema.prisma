generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum LeagueState {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PayoutPreset {
  WTA
  TOP_2
  TOP_3
}

enum PaymentStatus {
  PENDING
  PAID
  WAIVED
  REFUNDED
}

enum MatchStatus {
  PENDING
  AWAITING_REPORT
  AWAITING_CONFIRM
  CONFIRMED
  DISPUTED
  ORGANIZER_DECIDED
}

model User {
  id                       String        @id @default(cuid())
  email                    String        @unique
  emailVerified            DateTime?
  passwordHash             String
  displayName              String
  // v1.5: short URL handle for `/p/[handle]`. Nullable in schema so existing
  // rows can be backfilled; runtime always populates for new signups.
  handle                   String?       @unique
  ageConfirmed             Boolean       @default(false)
  stripeConnectedAccountId String?
  accounts                 Account[]
  sessions                 Session[]
  organizedLeagues         League[]
  organizedSeasons         Season[]      @relation("UserSeasons")
  captainedTeams           Team[]
  matchReports             MatchReport[] @relation("MatchReportReporter")
  matchesResolved          Match[]       @relation("MatchResolver")
  matchesDisputed          Match[]       @relation("MatchDisputer")
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model League {
  id                   String       @id @default(cuid())
  slug                 String       @unique
  name                 String
  description          String?
  game                 String
  teamSize             Int
  maxTeams             Int
  buyInCents           Int
  payoutPreset         PayoutPreset @default(WTA)
  paymentInstructions  String?
  prizeNotes           String?
  state                LeagueState  @default(DRAFT)
  organizerId          String
  // v1.5: optional grouping with other leagues from the same organizer.
  seasonId             String?
  inviteToken          String       @unique
  publishedAt          DateTime?
  registrationClosesAt DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  organizer User    @relation(fields: [organizerId], references: [id], onDelete: Restrict)
  season    Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  teams     Team[]
  matches   Match[]

  @@index([organizerId])
  @@index([seasonId])
}

// v1.5: groups multiple leagues into a recurring series. The organizer of
// the season also organizes (or at least owns) every league in it.
model Season {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  organizerId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer User     @relation("UserSeasons", fields: [organizerId], references: [id], onDelete: Restrict)
  leagues   League[]

  @@index([organizerId])
}

model Team {
  id             String        @id @default(cuid())
  leagueId       String
  name           String
  captainUserId  String
  paymentStatus  PaymentStatus @default(PENDING)
  finalPlacement Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  league               League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  captain              User              @relation(fields: [captainUserId], references: [id], onDelete: Restrict)
  roster               TeamRosterEntry[]
  matchesAsTeamA       Match[]           @relation("MatchTeamA")
  matchesAsTeamB       Match[]           @relation("MatchTeamB")
  matchesWon           Match[]           @relation("MatchWinner")
  matchReportsAsWinner MatchReport[]     @relation("MatchReportWinner")

  @@unique([leagueId, captainUserId])
  @@index([leagueId])
  @@index([captainUserId])
}

model TeamRosterEntry {
  id          String   @id @default(cuid())
  teamId      String
  displayName String
  position    Int
  createdAt   DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, position])
  @@index([teamId])
}

model Match {
  id               String      @id @default(cuid())
  leagueId         String
  round            Int
  bracketPosition  Int
  teamAId          String?
  teamBId          String?
  winnerTeamId     String?
  status           MatchStatus @default(PENDING)
  confirmedAt      DateTime?
  resolvedByUserId String?
  disputedAt       DateTime?
  disputedByUserId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  league     League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teamA      Team?         @relation("MatchTeamA", fields: [teamAId], references: [id], onDelete: SetNull)
  teamB      Team?         @relation("MatchTeamB", fields: [teamBId], references: [id], onDelete: SetNull)
  winner     Team?         @relation("MatchWinner", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  resolvedBy User?         @relation("MatchResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  disputedBy User?         @relation("MatchDisputer", fields: [disputedByUserId], references: [id], onDelete: SetNull)
  reports    MatchReport[]

  @@unique([leagueId, round, bracketPosition])
  @@index([leagueId])
}

model MatchReport {
  id                   String   @id @default(cuid())
  matchId              String
  reportedByUserId     String
  reportedWinnerTeamId String
  scoreText            String?
  createdAt            DateTime @default(now())

  match              Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reportedBy         User  @relation("MatchReportReporter", fields: [reportedByUserId], references: [id], onDelete: Restrict)
  reportedWinnerTeam Team  @relation("MatchReportWinner", fields: [reportedWinnerTeamId], references: [id], onDelete: Restrict)

  @@index([matchId])
}
